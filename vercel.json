{
  "version": 2,
  "builds": [
    {
      "src": "apps/shell/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/apps/shell"
      }
    },
    {
      "src": "apps/order/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/apps/order"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/apps/shell/$1"
    }
  ]
}